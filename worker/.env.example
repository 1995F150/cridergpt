# ---- Required ----
SUPABASE_URL=https://udpldrrpebdyuiqdtqnq.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste-your-service-role-key-here

# ---- Optional ----
# Friendly name shown in worker_nodes + worker_jobs.worker_name
WORKER_NAME=ubuntu-prod-1

# Comma-separated list of job types this worker accepts.
# Leave blank to accept ALL types.
JOB_TYPES=ping_test,echo_text

# Seconds between empty polls
POLL_INTERVAL=3

# Seconds between heartbeat upserts
HEARTBEAT_INTERVAL=30
